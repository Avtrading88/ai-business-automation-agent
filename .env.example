# Copy this file to .env and add real secrets only when you are ready.
# Never commit a real .env file to GitHub.

# HubSpot private app token
HUBSPOT_PRIVATE_APP_TOKEN=your_private_app_token_here

# QuickBooks / Intuit OAuth sandbox credentials
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id_here
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret_here
QUICKBOOKS_REDIRECT_URI=http://localhost:8501

# These are received after OAuth authorization.
QUICKBOOKS_ACCESS_TOKEN=your_quickbooks_access_token_here
QUICKBOOKS_REFRESH_TOKEN=your_quickbooks_refresh_token_here
QUICKBOOKS_REALM_ID=your_quickbooks_company_realm_id_here

# Optional: copy the full redirected URL here temporarily if you prefer not to paste it into Streamlit.
# Do not commit this file after adding real values.
QUICKBOOKS_LAST_REDIRECT_URL=

# Required for real QuickBooks invoice creation. Use an Item/Product/Service ID from your sandbox company.
QUICKBOOKS_DEFAULT_ITEM_ID=

# Email notifications / SMTP
# For Gmail, create an App Password and use smtp.gmail.com:587.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=your_email@example.com
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password_here
