# Development environment template
APP_ENV=development

# Optional HubSpot token
HUBSPOT_ACCESS_TOKEN=

# Optional QuickBooks sandbox credentials
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
